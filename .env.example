# =============================================================================
# ARBITER - ENVIRONMENT VARIABLES
# =============================================================================

# =============================================================================
# Application
# =============================================================================

NODE_ENV=development

NEXT_PUBLIC_APP_NAME=Arbiter
NEXT_PUBLIC_APP_VERSION=0.1.0
NEXT_PUBLIC_APP_URL=http://localhost:3000

ARBITER_API_SECRET=replace-with-32-char-random-secret
ARBITER_CONSISTENCY_WINDOW_TARGET_MS=200

# =============================================================================
# Authentication
# =============================================================================

NEXTAUTH_SECRET=replace-with-32-char-random-secret
NEXTAUTH_URL=http://localhost:3000

# =============================================================================
# AWS General
# =============================================================================

AWS_REGION=us-east-1
AWS_PROFILE=default
AWS_ACCOUNT_ID=123456789012

# =============================================================================
# Aurora DSQL (Permission Store)
# =============================================================================

DSQL_CLUSTER_ENDPOINT=your-cluster-id.dsql.us-east-1.on.aws
DSQL_REGION=us-east-1
DSQL_DATABASE=postgres

# =============================================================================
# DynamoDB (Permission Cache)
# =============================================================================

DYNAMODB_PERMISSION_CACHE_TABLE=arbiter-permission-cache
DYNAMODB_AGENT_CACHE_TABLE=arbiter-agent-cache
DYNAMODB_REGION=us-east-1

# =============================================================================
# Aurora PostgreSQL (Audit Log)
# =============================================================================

POSTGRES_HOST=arbiter-audit.cluster-xxxxx.us-east-1.rds.amazonaws.com
POSTGRES_PORT=5432
POSTGRES_DB=arbiter_audit
POSTGRES_USER=arbiter_app
POSTGRES_PASSWORD=from-secrets-manager
POSTGRES_SSL=true

# =============================================================================
# EventBridge
# =============================================================================

EVENTBRIDGE_BUS_NAME=arbiter-events
EVENTBRIDGE_REGION=us-east-1

# =============================================================================
# AWS Secrets Manager
# =============================================================================

SECRETS_MANAGER_REGION=us-east-1

# =============================================================================
# CloudWatch / Observability
# =============================================================================

CLOUDWATCH_NAMESPACE=Arbiter
LOG_LEVEL=info

# =============================================================================
# Vercel
# =============================================================================

VERCEL_ENV=development

# =============================================================================
# Demo Mode
# =============================================================================

DEMO_MODE=false
DEMO_TENANT_ID=demo-tenant-arbiter-2025

# =============================================================================
# Future AI Gateway (Phase 6)
# =============================================================================

MCP_SERVER_NAME=arbiter-mcp
MCP_SERVER_VERSION=0.1.0